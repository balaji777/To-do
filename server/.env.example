PORT=4000
JWT_SECRET=replace-with-a-long-random-string
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=onboarding@resend.dev
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Optional: absolute path for the SQLite file, for hosts with a separate persistent disk
# (e.g. /var/data/todo.db on Render). Defaults to server/todo.db if unset.
DB_PATH=

# Optional: restrict CORS to your deployed client's origin (e.g. https://your-app.onrender.com).
# Defaults to allowing all origins if unset, which is fine for local dev.
CLIENT_ORIGIN=
